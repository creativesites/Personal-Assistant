# PostgreSQL — credentials for the local Docker postgres container
DB_USER=zuri
DB_PASSWORD=change-me-db-password
DB_NAME=zuri_prod

# Redis (password protects the local Redis container)
REDIS_PASSWORD=change-me-redis-password

# Zuri JWT secret — min 32 chars random string
JWT_SECRET=change-me-min-64-char-random-string

# Shared secret between Vercel (web) and this API — must match INTERNAL_API_SECRET on Vercel
INTERNAL_API_SECRET=change-me-min-32-char-random-string

# Allowed CORS origins (comma-separated). Set to your Vercel deployment URL.
# Example: https://zuri-personal-assistant-delta.vercel.app
CORS_ORIGIN=https://zuri-personal-assistant-delta.vercel.app

# AI Providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
DEFAULT_AI_MODEL=gemini/gemini-2.0-flash
