# Supabase PostgreSQL connection string
# Get from: Supabase dashboard → Settings → Database → Connection string (URI mode)
# Use the "Session mode" pooler on port 5432 for migrations, "Transaction mode" port 6543 for the app
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Redis (password protects the local Redis container)
REDIS_PASSWORD=change-me-redis-password

# Zuri JWT secret — min 32 chars random string
JWT_SECRET=change-me-min-64-char-random-string

# Shared secret between Vercel (web) and this API — must match INTERNAL_API_SECRET on Vercel
INTERNAL_API_SECRET=change-me-min-32-char-random-string

# AI Providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
DEFAULT_AI_MODEL=gemini-3.5-flash
