# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/inbox
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/inbox

# Shared secret for internal API calls (set same value in services/api/.env)
INTERNAL_API_SECRET=change-me-min-32-char-random-string

# Backend API URL (server-side only — no NEXT_PUBLIC prefix)
API_URL=http://localhost:3000

# Backend API URL (client-side — exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:3000
