# Supabase PostgreSQL connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://zuri:zuridev@localhost:5432/zuri_dev
REDIS_URL=redis://localhost:6379
PORT=8000
ENVIRONMENT=development
API_URL=http://localhost:3000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
DASHSCOPE_API_KEY=   # standard DashScope API (only needed if NOT using a private MaaS workspace)

# Alibaba private MaaS workspace — two endpoint formats:
# Use ALIBABA_API_HOST (native DashScope /api/v1) — recommended
# ALIBABA_OPENAI_COMPATIBLE_HOST (/compatible-mode/v1) is the OpenAI-compat alternative
ALIBABA_AI_API_KEY=
ALIBABA_API_HOST=            # e.g. https://ws-xxxx.ap-southeast-1.maas.aliyuncs.com/api/v1
ALIBABA_OPENAI_COMPATIBLE_HOST=  # e.g. https://ws-xxxx.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1

DEFAULT_AI_MODEL=gemini/gemini-3.5-flash
