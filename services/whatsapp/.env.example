# Path to Chromium binary (optional; open-wa uses bundled Chromium if not set)
# CHROMIUM_EXECUTABLE_PATH=/opt/pw-browsers/chromium

# Supabase Storage for incoming WhatsApp media (images/documents/etc).
# Bucket: 'chat-media' (public, create it in the Supabase dashboard).
# Uses the service-role key (not the anon key) — this is a trusted backend
# service, not a user's browser session. Falls back to local disk (MEDIA_DIR)
# if unset.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
